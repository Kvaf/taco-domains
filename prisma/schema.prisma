generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Auth.js Required Models ───────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  role          String    @default("USER") // USER, ADMIN
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  domains             Domain[]
  marketplaceListings MarketplaceListing[] @relation("SellerListings")
  bids                Bid[]
  salesTransactions   Transaction[]        @relation("Seller")
  buyTransactions     Transaction[]        @relation("Buyer")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Site Settings (Admin Feature Flags) ─────────────────────────────────────

model SiteSettings {
  id                 String   @id @default("default")
  domainSearch       Boolean  @default(true)
  domainRegistration Boolean  @default(true)
  dnsManagement      Boolean  @default(true)
  marketplace        Boolean  @default(true)
  signup             Boolean  @default(true)
  maintenanceMode    Boolean  @default(false)
  maintenanceMessage String?
  updatedAt          DateTime @updatedAt
}

// ─── Domain Models (Defined for later phases) ──────────────────────────────────

model Domain {
  id           String   @id @default(cuid())
  name         String   @unique
  userId       String
  tld          String
  status       String   @default("ACTIVE") // ACTIVE, PENDING, EXPIRED, TRANSFERRED
  registeredAt DateTime @default(now())
  expiresAt    DateTime
  autoRenew    Boolean  @default(true)
  locked       Boolean  @default(false)
  whoisPrivacy Boolean  @default(true)
  redirectUrl  String?
  redirectType String?  // "301" or "302"
  dnssec       Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user                User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  dnsRecords          DNSRecord[]
  marketplaceListings MarketplaceListing[]
  transactions        Transaction[]
}

model DNSRecord {
  id        String   @id @default(cuid())
  domainId  String
  type      String // A, AAAA, CNAME, MX, TXT, NS, SRV, CAA
  name      String
  value     String
  ttl       Int      @default(3600)
  priority  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
}

// ─── Marketplace Models (Defined for later phases) ─────────────────────────────

model MarketplaceListing {
  id            String    @id @default(cuid())
  domainId      String
  sellerId      String
  type          String // FIXED_PRICE, AUCTION
  price         Float
  minBid        Float?
  auctionEndsAt DateTime?
  status        String    @default("ACTIVE") // ACTIVE, SOLD, CANCELLED, EXPIRED
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  seller User   @relation("SellerListings", fields: [sellerId], references: [id], onDelete: Cascade)
  bids   Bid[]
}

model Bid {
  id        String   @id @default(cuid())
  listingId String
  bidderId  String
  amount    Float
  createdAt DateTime @default(now())

  listing MarketplaceListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  bidder  User               @relation(fields: [bidderId], references: [id], onDelete: Cascade)
}

model Transaction {
  id        String   @id @default(cuid())
  domainId  String
  sellerId  String
  buyerId   String
  amount    Float
  type      String // PURCHASE, AUCTION_WIN
  createdAt DateTime @default(now())

  domain Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)
  seller User   @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer  User   @relation("Buyer", fields: [buyerId], references: [id], onDelete: Cascade)
}
